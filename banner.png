<svg width="1280" height="320" viewBox="0 0 1280 320" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <filter id="softShadow" x="-20%" y="-20%" width="140%" height="140%">
      <feDropShadow dx="0" dy="0" stdDeviation="14" flood-color="#000000" flood-opacity="0.55"/>
    </filter>
  </defs>

  <rect width="1280" height="320" fill="#06090e"/>

  <!-- particle network, matching the site's live canvas background -->
  <g stroke="#2ea043" stroke-width="0.7">
    <line x1="46" y1="118" x2="128" y2="150" opacity="0.35"/>
    <line x1="128" y1="150" x2="160" y2="230" opacity="0.25"/>
    <line x1="46" y1="270" x2="90" y2="300" opacity="0.3"/>
    <line x1="30" y1="150" x2="46" y2="118" opacity="0.2"/>
    <line x1="1234" y1="112" x2="1150" y2="145" opacity="0.35"/>
    <line x1="1150" y1="145" x2="1195" y2="215" opacity="0.25"/>
    <line x1="1150" y1="145" x2="1080" y2="120" opacity="0.3"/>
    <line x1="1220" y1="270" x2="1160" y2="290" opacity="0.3"/>
    <line x1="1160" y1="290" x2="1110" y2="255" opacity="0.25"/>
    <line x1="620" y1="40" x2="660" y2="30" opacity="0.2"/>
    <line x1="700" y1="60" x2="660" y2="30" opacity="0.2"/>
  </g>
  <g fill="#2ea043">
    <circle cx="46" cy="118" r="2.4" opacity="0.8"/>
    <circle cx="128" cy="150" r="2.4" opacity="0.8"/>
    <circle cx="160" cy="230" r="2.4" opacity="0.8"/>
    <circle cx="46" cy="270" r="2.4" opacity="0.8"/>
    <circle cx="90" cy="300" r="2.4" opacity="0.8"/>
    <circle cx="30" cy="150" r="2.4" opacity="0.8"/>
    <circle cx="1234" cy="112" r="2.4" opacity="0.8"/>
    <circle cx="1150" cy="145" r="2.4" opacity="0.8"/>
    <circle cx="1195" cy="215" r="2.4" opacity="0.8"/>
    <circle cx="1080" cy="120" r="2.4" opacity="0.8"/>
    <circle cx="1220" cy="270" r="2.4" opacity="0.8"/>
    <circle cx="1160" cy="290" r="2.4" opacity="0.8"/>
    <circle cx="1110" cy="255" r="2.4" opacity="0.8"/>
    <circle cx="620" cy="40" r="2" opacity="0.6"/>
    <circle cx="660" cy="30" r="2" opacity="0.6"/>
    <circle cx="700" cy="60" r="2" opacity="0.6"/>
  </g>

  <!-- the site's own .container card, reproduced -->
  <rect x="240" y="90" width="800" height="140" rx="8" fill="#12161d" filter="url(#softShadow)"/>
  <rect x="240" y="90" width="800" height="140" rx="8" fill="none" stroke="#2ea043" stroke-opacity="0.4" stroke-width="1.5"/>

  <!-- logo + wordmark lockup, precisely centered as one unit -->
  <g transform="translate(413, 136)">
    <!-- icon, 56x56 -->
    <g>
      <circle cx="21" cy="24" r="13" fill="none" stroke="#2ea043" stroke-width="5"/>
      <line x1="30" y1="33" x2="43" y2="46" stroke="#2ea043" stroke-width="5.5" stroke-linecap="round"/>
      <circle cx="21" cy="24" r="3.6" fill="#58a6ff"/>
    </g>
    <text x="74" y="38" font-family="'Segoe UI', Tahoma, Geneva, Verdana, sans-serif" font-size="40" font-weight="700" letter-spacing="4" fill="#2ea043" textLength="380" lengthAdjust="spacingAndGlyphs">QUICKDIG UI</text>
  </g>
</svg>
